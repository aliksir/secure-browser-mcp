{
  "name": "secure-browser-mcp",
  "version": "0.1.0",
  "description": "Security-first browser automation MCP server. Zero telemetry, sensitive data masking, local-only. Powered by Playwright.",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "secure-browser-mcp": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "README.ja.md",
    "SKILL.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "playwright",
    "browser",
    "automation",
    "security",
    "model-context-protocol",
    "claude-code",
    "sensitive-data",
    "masking",
    "local-only"
  ],
  "author": "aliksir",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aliksir/secure-browser-mcp.git"
  },
  "homepage": "https://github.com/aliksir/secure-browser-mcp#readme",
  "bugs": {
    "url": "https://github.com/aliksir/secure-browser-mcp/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "playwright": "^1.52.0"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "@types/node": "^22.0.0"
  }
}
